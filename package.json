{
  "name": "junk",
  "version": "1.5.0",
  "description": "A flying scratchpad for macOS, Windows and Linux. One shortcut. No chrome. No cloud.",
  "main": "src/main.js",
  "author": "Paul Fleury <hello@paulfleury.com>",
  "license": "MIT",
  "private": false,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.paulfleury.junk",
    "productName": "Junk",
    "copyright": "Copyright © 2026 Paul Fleury",
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "publish": null,
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "darkModeSupport": true,
      "identity": null,
      "gatekeeperAssess": false,
      "hardenedRuntime": false,
      "entitlements": null,
      "entitlementsInherit": null
    },
    "dmg": {
      "title": "Junk",
      "background": "assets/dmg-background.png",
      "window": { "width": 620, "height": 400 },
      "contents": [
        { "x": 140, "y": 200, "type": "file" },
        { "x": 380, "y": 200, "type": "link", "path": "/Applications" },
        { "x": 560, "y": 200, "type": "file", "path": "assets/README.txt" }
      ]
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Junk"
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Utility",
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ]
    }
  }
}
