{
  "name": "junk",
  "version": "1.2.0",
  "description": "A flying scratchpad for macOS. Hit CMD+J, type, paste, think. Gone when you're done.",
  "main": "src/main.js",
  "author": "Paul Fleury <hello@paulfleury.com>",
  "license": "MIT",
  "private": false,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --arm64 --x64",
    "build:arm64": "electron-builder --mac --arm64",
    "build:x64": "electron-builder --mac --x64",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.paulfleury.junk",
    "productName": "Junk",
    "copyright": "Copyright © 2026 Paul Fleury",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "darkModeSupport": true,
      "identity": null,
      "gatekeeperAssess": false,
      "hardenedRuntime": false,
      "entitlements": null,
      "entitlementsInherit": null
    },
    "dmg": {
      "title": "Junk",
      "background": "assets/dmg-background.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        { "x": 150, "y": 185, "type": "file" },
        { "x": 390, "y": 185, "type": "link", "path": "/Applications" }
      ]
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "paulfxyz",
      "repo": "junk"
    }
  }
}
